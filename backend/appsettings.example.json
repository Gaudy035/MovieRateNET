{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DbConnection": "Host=<HOST>; Port=<PORT>; Database=<DB>; Username=<DB_USER>; Password=<PASS>"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "Jwt": {
    "Key": "<JWT_SECRET_MIN_32_CHARACTERS_LONG>"
  }
}
